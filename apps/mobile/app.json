{
  "expo": {
    "name": "spenlog",
    "slug": "spenlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "spenlog",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "홈 화면을 꾸미기 위해 사진 라이브러리에 접근할 수 있어요."
        }
      ],
      "expo-web-browser"
    ]
  }
}
