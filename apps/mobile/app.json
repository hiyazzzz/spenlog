{
  "expo": {
    "name": "spenlog",
    "slug": "spenlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "spenlog",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/a99c1ae4-b199-4f8d-8762-4b30f52c4e94",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spenlog.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.spenlog.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "홈 화면을 꾸미기 위해 사진 라이브러리에 접근할 수 있어요."
        }
      ],
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ],
      "expo-web-browser",
      "expo-updates",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "a99c1ae4-b199-4f8d-8762-4b30f52c4e94"
      }
    }
  }
}
