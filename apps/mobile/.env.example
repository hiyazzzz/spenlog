EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# 구글 로그인 연동 전, 임시로 데이터를 조회할 web 계정의 user id
EXPO_PUBLIC_TEST_USER_ID=

# AI 파싱(/api/ai-input), 예산 추천(/api/budget-recommend) 호출용 웹 배포 URL
EXPO_PUBLIC_API_URL=https://spenlog.vercel.app

# 개발 환경 프리미엄 전체 해제 (개발 중: true / 출시 전: false)
EXPO_PUBLIC_PREMIUM_BYPASS=true
